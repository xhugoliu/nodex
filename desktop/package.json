{
  "name": "nodex-desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "build": "tauri build",
    "build:web": "tsc && vite build",
    "check": "tsc --noEmit",
    "check:tauri": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:core": "cargo test --manifest-path ../Cargo.toml",
    "test:logic": "node --import tsx --test src/app-helpers.ai-route.test.ts src/workbench.ai-route-surface.test.tsx src/workbench.source-context-surface.test.tsx src/workbench.node-context-surface.test.tsx src/workbench.side-pane.test.tsx",
    "check:all": "npm run check && npm run test:logic && npm run check:tauri && npm run test:core"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@tauri-apps/cli": "^2.10.1",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "tailwindcss": "^4.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.0",
    "vite": "^8.0.2"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@xyflow/react": "^12.10.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
