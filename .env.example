# Copy this file to `.env.local` for local development.
# Never commit real secrets.

OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-5.4-mini
# LangChain OpenAI pilot reuses the same OPENAI_* settings above.
# Install on demand with:
# python3 -m pip install -U langchain-openai
# Optional:
# OPENAI_BASE_URL=https://api.openai.com/v1/responses
# OPENAI_PROJECT=
# OPENAI_ORGANIZATION=
# OPENAI_TIMEOUT_SECONDS=120
# OPENAI_MAX_RETRIES=3
# OPENAI_BACKOFF_SECONDS=2
# OPENAI_MAX_BACKOFF_SECONDS=20
# OPENAI_REASONING_EFFORT=medium

# Gemini runner example:
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.5-pro
# GOOGLE_GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# GEMINI_TIMEOUT_SECONDS=120
# GEMINI_MAX_RETRIES=3
# GEMINI_BACKOFF_SECONDS=2
# GEMINI_MAX_BACKOFF_SECONDS=20
